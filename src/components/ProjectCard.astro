---
import type { CollectionEntry } from "astro:content";

interface Props {
  project: CollectionEntry<"projects">["data"];
}

const { project } = Astro.props;

const kindLabel = project.kind;
---

<article class="border-b border-border py-8 first:pt-0 last:border-b-0">
  <div class="flex items-baseline justify-between gap-6">
    <h3 class="m-0 font-serif text-xl font-normal leading-tight">
      <a
        href={project.url}
        target="_blank"
        rel="noopener noreferrer"
        class="text-white no-underline hover:text-accent hover:no-underline"
      >
        {project.name}
      </a>
    </h3>
    <span class="shrink-0 font-serif text-sm italic text-muted">
      {kindLabel}
    </span>
  </div>
  <p class="mt-2 mb-0 text-muted">{project.description}</p>
  {
    project.links && project.links.length > 0 && (
      <ul class="mt-3 flex list-none flex-wrap gap-x-4 p-0 text-sm">
        {project.links.map((link) => (
          <li>
            <a
              href={link.url}
              target="_blank"
              rel="noopener noreferrer"
              class="text-accent no-underline hover:text-accent-strong hover:underline"
            >
              {link.label} <span aria-hidden="true">&#x2197;</span>
            </a>
          </li>
        ))}
      </ul>
    )
  }
  {
    project.tags && project.tags.length > 0 && (
      <ul class="mt-3 flex list-none flex-wrap gap-x-2 p-0 font-mono text-xs text-muted">
        {project.tags.map((tag, i) => (
          <li class="flex items-center gap-2">
            {i > 0 && <span class="text-muted/40">·</span>}
            <span>{tag}</span>
          </li>
        ))}
      </ul>
    )
  }
</article>
