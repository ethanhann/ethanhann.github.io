---
import {getCollection} from "astro:content";
import Layout from "../layouts/Layout.astro";

const posts = (await getCollection("blog")).sort(
    (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<Layout title="Blog · Ethan Hann" description="Blog posts by Ethan Hann.">
    <h1>Blog</h1>

    {
        posts.length > 0 ? (
                <ul class="mt-10 space-y-8 list-none p-0">
                    {posts.map((post) => (
                            <li>
                                <a href={`/blog/${post.id}`} class="no-underline hover:no-underline group">
              <span class="text-white group-hover:text-accent-strong transition-colors">
                {post.data.title}
              </span>
                                    <time
                                            datetime={post.data.date.toISOString().slice(0, 10)}
                                            class="block text-sm text-muted mt-1"
                                    >
                                        {post.data.date.toLocaleDateString("en-US", {
                                            year: "numeric",
                                            month: "long",
                                            day: "numeric",
                                        })}
                                    </time>
                                    {post.data.description && (
                                            <p class="text-muted text-sm mt-1 mb-0">{post.data.description}</p>
                                    )}
                                </a>
                            </li>
                    ))}
                </ul>
        ) : (
                <p class="text-muted">Nothing here yet.</p>
        )
    }
</Layout>
